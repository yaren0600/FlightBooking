<style>
    /* --- GENEL ALAN AYARLARI --- */
    .fly-next-area {
        padding: 100px 0;
        background-color: #f8faff;
        font-family: 'Poppins', sans-serif; /* Projenin fontu farklıysa ona uyum sağlar */
    }

    .section-title .sub-title {
        color: #3b43e1;
        font-weight: 700;
        text-transform: uppercase;
        display: block;
        margin-bottom: 10px;
