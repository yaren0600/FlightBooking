    }

    /* --- MODERN NAVİGASYON (BUTONLAR) --- */
    .fly-next-nav {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 60px;
        flex-wrap: wrap;
    }

        .fly-next-nav button {
            background: #ffffff;
            border: 1px solid #e0e4f0;
            color: #4a5568;
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            position: relative;
        }

            /* Görseldeki o garip yuvarlakları temizlemek için reset */
            .fly-next-nav button::before,
            .fly-next-nav button::after {
                display: none !important;
                content: none !important;
            }

            .fly-next-nav button:hover {
                background: #f0f3ff;
                color: #3b43e1;
                border-color: #3b43e1;
                transform: translateY(-3px);
            }

            .fly-next-nav button.active {
                background: #3b43e1;
                color: #ffffff;
                border-color: #3b43e1;
                box-shadow: 0 8px 20px rgba(59, 67, 225, 0.2);
            }

            .fly-next-nav button i {
                font-size: 18px;
            }

    /* --- KART TASARIMI --- */
    .fly-next-item {
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #eee;
        overflow: hidden;
        margin-bottom: 30px;
        height: 100%;
    }

        .fly-next-item:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08) !important;
            border-color: #3b43e1;
        }

    .fly-next-thumb {
        position: relative;
        overflow: hidden;
    }

        .fly-next-thumb img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            transition: 0.5s;
        }

    .fly-next-item:hover .fly-next-thumb img {
        transform: scale(1.1);
    }

    .fly-next-content {
        padding: 25px;
    }

    /* Tarih Badge */
    .date-badge {
        display: inline-block;
        background: rgba(59, 67, 225, 0.08);
        color: #3b43e1;
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .fly-next-content .title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 0;
        color: #1c2331;
    }

    .exchange-btn {
        display: inline-block;
        margin: 8px 0;
        color: #3b43e1;
        font-size: 18px;
        transition: 0.4s;
    }

    .fly-next-item:hover .exchange-btn {
        transform: rotate(180deg);
    }

    /* Havayolu Logosu */
    .air-logo-wrap {
        margin: 15px 0;
        padding-top: 15px;
        border-top: 1px dashed #e5e5e5;
    }

        .air-logo-wrap img {
            max-height: 24px;
            filter: grayscale(100%);
            opacity: 0.5;
            transition: 0.3s;
        }

    .fly-next-item:hover .air-logo-wrap img {
        filter: grayscale(0%);
        opacity: 1;
    }

    /* Fiyat ve Alt Kısım */
    .content-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 15px;
    }

        .content-bottom p {
            margin-bottom: 0;
            font-size: 13px;
            color: #707070;
        }

        .content-bottom .price {
            color: #ff5e14;
            font-weight: 800;
            font-size: 24px;
            margin: 0;
        }
</style>

